{
  "name": "ivanbaric/seo",
  "description": "Reusable, model-agnostic SEO infrastructure for Laravel applications.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "ivanbaric/corexis": "^0.1 || ^1.0",
    "illuminate/support": "^11.0 || ^12.0 || ^13.0",
    "illuminate/database": "^11.0 || ^12.0 || ^13.0",
    "illuminate/console": "^11.0 || ^12.0 || ^13.0",
    "illuminate/contracts": "^11.0 || ^12.0 || ^13.0"
  },
  "autoload": {
    "psr-4": {
      "IvanBaric\\Seo\\": "src/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "IvanBaric\\Seo\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "laravel/pint": "^1.24",
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^9.0 || ^10.0",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^10.5 || ^11.5"
  },
  "extra": {
    "laravel": {
      "providers": [
        "IvanBaric\\Seo\\SeoServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "phpunit",
    "format": "pint"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
